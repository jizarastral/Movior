# Where quote requests are delivered (defaults to info@movior.co)
QUOTE_TO_EMAIL=info@movior.co

# Optional but recommended for production email delivery.
# Without this, the form still works via FormSubmit (activate once via email to info@movior.co).
# Get a free API key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxx

# After you verify movior.co in Resend, set a from address on your domain, e.g.:
# QUOTE_FROM_EMAIL=Movior Transport <info@movior.co>
